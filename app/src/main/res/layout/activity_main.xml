<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_surface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rockey"
        android:textColor="@color/ink"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Rokid Local • OpenClaw Bridge 2478"
        android:textColor="@color/muted"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_status_card"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/connectionStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_state_pill"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="启动中"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="正在连接 Rokid 眼镜与 OpenClaw..."
            android:textColor="@color/ink"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/liveTranscriptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
        android:text="等待就绪"
            android:textColor="@color/muted"
            android:textSize="13sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/bg_chat_card"
        android:fillViewport="true">

        <TextView
            android:id="@+id/conversationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:textColor="@color/ink"
            android:textSize="14sp" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/voiceButton"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:minHeight="52dp"
        android:text="开始语音"
        android:textAllCaps="false"
        android:textColor="@color/accent_dark"
        android:textSize="16sp"
        app:backgroundTint="@color/accent"
        app:cornerRadius="26dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/reconnectButton"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="44dp"
        android:text="重新连接"
        android:textAllCaps="false"
        android:textColor="@color/ink"
        android:textSize="14sp"
        app:cornerRadius="20dp"
        app:strokeColor="@color/stroke"
        app:strokeWidth="1dp" />

</LinearLayout>
